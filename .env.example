# Cycling Wear — variáveis de ambiente
# Copie este arquivo para `.env` e preencha os valores.
# NUNCA commite o arquivo `.env` real (já está no .gitignore).

# Client ID gerado no Google Cloud Console (Web application).
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com

# O e-mail Google autorizado a entrar no app (apenas um).
ALLOWED_EMAIL=seuemail@gmail.com

# Segredo usado para assinar o cookie de sessão. Gere algo longo e aleatório.
# Sugestão: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=troque-este-valor-por-uma-string-aleatoria-longa

# Em produção (Render), defina NODE_ENV=production — isso ativa cookies seguros.
# Para desenvolvimento local, deixe em branco ou não defina.
# NODE_ENV=production

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# String de conexão do cluster gratuito (M0) no MongoDB Atlas.
# Formato: mongodb+srv://<user>:<senha>@<cluster>.mongodb.net/<banco>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://usuario:senha@cluster0.xxxxx.mongodb.net/cycling-wear?retryWrites=true&w=majority

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Credenciais do painel em https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=seu-cloud-name
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
